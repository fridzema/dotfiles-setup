#!/usr/bin/env bash
set -euo pipefail

# helpers/macos-defaults.sh hash: {{ include "helpers/macos-defaults.sh" | sha256sum }}

# shellcheck source=helpers/macos-defaults.sh
source "{{ .chezmoi.sourceDir }}/helpers/macos-defaults.sh"

echo "==> Applying Safari defaults..."

close_system_settings

# macOS Ventura+ sandboxes Safari preferences — defaults write is blocked
# unless the terminal has Full Disk Access. Try writing and skip gracefully
# if the sandbox blocks it.
SAFARI_PLIST="$HOME/Library/Containers/com.apple.Safari/Data/Library/Preferences/com.apple.Safari.plist"

if ! defaults write "$SAFARI_PLIST" HomePage -string "about:blank" 2>/dev/null; then
  echo "==> SKIPPED: Safari defaults require Full Disk Access for your terminal."
  echo "    Grant it in System Settings > Privacy & Security > Full Disk Access,"
  echo "    then re-run to apply Safari preferences."
  exit 0
fi

# Don't send search queries to Apple
set_default "$SAFARI_PLIST" UniversalSearchEnabled bool false
set_default "$SAFARI_PLIST" SuppressSearchSuggestions bool true

# Show full URL
set_default "$SAFARI_PLIST" ShowFullURLInSmartSearchField bool true

# Enable Develop menu and Web Inspector
set_default "$SAFARI_PLIST" IncludeDevelopMenu bool true
set_default "$SAFARI_PLIST" WebKitDeveloperExtrasEnabledPreferenceKey bool true
set_default "$SAFARI_PLIST" com.apple.Safari.ContentPageGroupIdentifier.WebKit2DeveloperExtrasEnabled bool true

# Warn about fraudulent websites
set_default "$SAFARI_PLIST" WarnAboutFraudulentWebsites bool true

# Auto-update extensions
set_default "$SAFARI_PLIST" InstallExtensionUpdatesAutomatically bool true

restart_app "Safari"

echo "==> Safari defaults applied."
